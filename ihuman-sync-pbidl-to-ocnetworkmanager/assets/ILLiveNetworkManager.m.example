                               failure:(void (^)(NSError *error))failure {
    ILILGetStudentRoomInfoReq *req = [[ILILGetStudentRoomInfoReq alloc] initWithPath:ILNetworkPathStudentLiveStudentRoomInfo];
    req.courseId = courseID;
    req.lessonId = lessonID;
    [self il_postRequest:req
         responseClass:[ILILGetStudentRoomInfoResp class]
              success:^(id response) {
        if (success) {
            success(response);
        }
    } failure:^(NSError *error, id response) {
        if (failure) {
            failure(error);
        }
    }];
}

