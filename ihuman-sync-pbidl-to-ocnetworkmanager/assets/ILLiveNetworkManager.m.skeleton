//  ILLiveNetworkManager.m
//  SuperClassSDK
//

#import <ILNetworkService/ILNetworkServiceImpl.h>
#import <ILNetworkService/ILNetworkConfigProtocol.h>
#import <ILNetworkService/ILNetworkServiceProtocol.h>
#import <ILProtocolBuffer/Serializer/ILProtobufSerializer.h>
#import <ILProtocolBuffer/Serializer/GPBMessage+ILNetworkRequest.h>
// {{ADDITIONAL_PB_IMPORTS}}
// 在此处加 PB 头文件 import，格式：
//   #import <ILProtocolBuffer/interface/<service_name>/<MessageFile>.pbobjc.h>
// service_name 是 proto 文件名去掉 _api/.proto 后缀（如 student_api、student_live_api、user_api）
// 一个 proto 通常对应多个 pbobjc 头文件，按 ilprotocolbuffer/ILProtocolBuffer/Classes/interface/ 下实际产物为准
#import "ILLiveNetworkManager.h"
#import "ILNetworkDefine.h"
#import "ILClassroomConfig.h"
#import "ILNetworkConfig.h"
#import "ILUser.h"

@interface ILLiveNetworkManager () <ILNetworkConfigProtocol>

@property (nonatomic, strong) id<ILNetworkServiceProtocol> service;
@property (nonatomic, copy) NSString *accessToken;
@property (nonatomic, copy) NSString *userID;

@end

@implementation ILLiveNetworkManager {
    id<ILNetworkServiceProtocol> _service;
}

+ (instancetype)shared {
    static ILLiveNetworkManager *instance = nil;
    static dispatch_once_t onceToken;
    dispatch_once(&onceToken, ^{
        instance = [[ILLiveNetworkManager alloc] init];
    });
    return instance;
}

+ (void)setupWithConfig:(ILClassroomConfig *)config {
    ILLiveNetworkManager *manager = [self shared];
    @synchronized (manager) {
        manager.accessToken = config.userSig;
        manager.userID = config.userID;
        manager.service = nil;
    }
}

+ (void)logout {
    ILLiveNetworkManager *manager = [self shared];
    @synchronized (manager) {
        manager.accessToken = nil;
        manager.userID = nil;
        manager.service = nil;
    }
}

- (id<ILNetworkServiceProtocol>)service {
    if (!_service) {
        ILProtobufSerializer *serializer = [[ILProtobufSerializer alloc] init];
        _service = [[ILNetworkServiceImpl alloc] initWithBaseURL:[ILNetworkConfig currentHost]
                                                          config:self
                                                      serializer:serializer];
    }
    return _service;
}

- (void)setService:(id<ILNetworkServiceProtocol>)service {
    _service = service;
}

#pragma mark - ILNetworkConfigProtocol

- (NSDictionary<NSString *, NSString *> *)currentHeaders {
    NSMutableDictionary<NSString *, NSString *> *headers = [NSMutableDictionary dictionary];
    @synchronized (self) {
        if (self.accessToken.length > 0) {
            headers[@"Authorization"] = [@"Bearer " stringByAppendingString:self.accessToken];
        }
        if (self.userID.length > 0) {
            headers[@"X-User-Id"] = self.userID;
        }
    }
    return [headers copy];
}

#pragma mark - 内部

+ (void)il_postRequest:(GPBMessage *)request
         responseClass:(Class)responseClass
               success:(ILNetworkSuccessBlock)success
               failure:(ILNetworkFailureBlock)failure {
    ILLiveNetworkManager *manager = [self shared];
    [self il_logPostCurlWithPath:request.networkPath request:request];
    [manager.service requestWithPath:request.networkPath
                                    method:ILHTTPMethodPost
                                   request:request
                             responseClass:responseClass
                                   success:success
                                   failure:failure];
}

// {{API_IMPLEMENTATIONS}}
// 在此处生成所有 API 方法实现，按 proto 文件分组，每组前加 #pragma mark - <分组名>
// 每个方法实现上方加一行中文注释，简述场景。
// 实现遵循固定模式（参见 references/api-method-pattern.md）：
//   - 类方法 +
//   - 用 [[ILIL<ReqName> alloc] initWithPath:ILNetworkPath<Xxx>] 创建 req，再赋值字段
//   - 调用 [self il_postRequest:req responseClass:[ILIL<RespName> class] success:... failure:...]
//   - success/failure block 透传到外层

@end
