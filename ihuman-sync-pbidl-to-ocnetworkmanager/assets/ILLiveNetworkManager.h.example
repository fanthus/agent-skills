//
//  ILLiveNetworkManager.h
//  SuperClassSDK
//
//  网络请求管理器（单例），封装业务 API，屏蔽底层请求细节
//

#import <Foundation/Foundation.h>
@import ILProtocolBuffer;
@class ILClassroomConfig;

NS_ASSUME_NONNULL_BEGIN

@interface ILLiveNetworkManager : NSObject

/// 初始化配置（必须在发起任何网络请求前调用一次）
+ (void)setupWithConfig:(ILClassroomConfig *)config;

/// 清除用户凭证，退出登录后调用
+ (void)logout;

#pragma mark - 直播基础

/// 学生加入房间（含断线重连），返回 RTC/IM 连接配置
/// 【场景】学生点击"进入课堂"，统一处理首次加入和断线重连；服务端按 userId 判断首次或重入，对客户端透明
/// 【返回】RTC 配置、频道列表、IM 配置、群组列表
+ (void)studentJoinWithRoomID:(int64_t)roomID
                     courseID:(int64_t)courseID
                     lessonID:(int64_t)lessonID
                     platform:(ILCCPlatformType)platform
                      success:(void (^)(ILILStudentJoinResp *resp))success
                      failure:(void (^)(NSError *error))failure;

/// 学生离开房间
/// 【场景】学生点击"退出课堂"或关闭应用；服务端更新状态并生成课堂报告
/// 【返回】参课时长、课堂报告
+ (void)studentLeaveWithRoomID:(int64_t)roomID
                   leaveReason:(NSString *)leaveReason
                       success:(void (^)(ILILStudentLeaveResp *resp))success
                       failure:(void (^)(NSError *error))failure;

/// 获取房间公共状态（可独立调用，不依赖 StudentJoin）
/// 【场景】StudentJoin 后调用，或断线重连时单独调用
/// 【返回】房间信息、当前课件、教师流列表、全员静音状态
+ (void)getStudentRoomInfoWithCourseID:(int64_t)courseID
                              lessonID:(int64_t)lessonID
                               success:(void (^)(ILILGetStudentRoomInfoResp *resp))success
                               failure:(void (^)(NSError *error))failure;

/// 获取学生基础数据（金币、禁言、拉黑）
/// 【场景】StudentJoin 后调用，或金币变化时单独调用
+ (void)getStudentInfoWithRoomID:(int64_t)roomID
                         success:(void (^)(ILILGetStudentInfoResp *resp))success
                         failure:(void (^)(NSError *error))failure;

/// 获取小组成员数据（含金币）
/// 【场景】StudentJoin 后用 my_group_id 查询；返回小组信息和成员列表
+ (void)getStudentGroupInfoWithRoomID:(int64_t)roomID
                              groupID:(int64_t)groupID
                              success:(void (^)(ILILGetStudentGroupInfoResp *resp))success
                              failure:(void (^)(NSError *error))failure;

/// 获取互动状态汇总（连麦、举手、答题、投票、签到、抢麦、计时器）
/// 【场景】StudentJoin 后调用，或连麦/活动状态变化时单独调用
+ (void)getStudentActivityProgressWithRoomID:(int64_t)roomID
                                     success:(void (^)(ILILGetStudentActivityProgressResp *resp))success
                                     failure:(void (^)(NSError *error))failure;

/// 获取连麦进度（拆分接口）
/// 【场景】只需连麦和举手状态时调用，减少数据传输
+ (void)getStudentSpeakProgressWithRoomID:(int64_t)roomID
                                  success:(void (^)(ILILGetStudentSpeakProgressResp *resp))success
                                  failure:(void (^)(NSError *error))failure;

/// 获取答题进度（拆分接口）
+ (void)getStudentQuizProgressWithRoomID:(int64_t)roomID
                                 success:(void (^)(ILILGetStudentQuizProgressResp *resp))success
                                 failure:(void (^)(NSError *error))failure;

/// 获取投票进度（拆分接口）
+ (void)getStudentVoteProgressWithRoomID:(int64_t)roomID
                                 success:(void (^)(ILILGetStudentVoteProgressResp *resp))success
                                 failure:(void (^)(NSError *error))failure;

/// 获取签到进度（拆分接口）
+ (void)getStudentSignInProgressWithRoomID:(int64_t)roomID
                                   success:(void (^)(ILILGetStudentSignInProgressResp *resp))success
                                   failure:(void (^)(NSError *error))failure;

/// 获取抢麦进度（拆分接口）
+ (void)getStudentGrabMicProgressWithRoomID:(int64_t)roomID
                                    success:(void (^)(ILILGetStudentGrabMicProgressResp *resp))success
                                    failure:(void (^)(NSError *error))failure;

/// 获取计时器进度（拆分接口）
+ (void)getStudentTimerProgressWithRoomID:(int64_t)roomID
                                  success:(void (^)(ILILGetStudentTimerProgressResp *resp))success
                                  failure:(void (^)(NSError *error))failure;

/// 获取回放互动题目内容及学生历史作答记录
/// 【场景】学生观看回放时，进度到达互动题节点时调用
/// 【返回】题目内容、正确答案、学生历史答案及是否已获得金币
+ (void)getStudentReplayQuizWithRoomID:(int64_t)roomID
                                quizID:(int64_t)quizID
                               success:(void (^)(ILILGetStudentReplayQuizResp *resp))success
                               failure:(void (^)(NSError *error))failure;

/// 获取学生课堂学习报告
/// 【返回】上课时长、金币数、答题统计、互动次数
+ (void)getStudentClassReportWithRoomID:(int64_t)roomID
                                success:(void (^)(ILILGetStudentClassReportResp *resp))success
                                failure:(void (^)(NSError *error))failure;

/// 获取直播回放信息
/// 【返回】回放 URL、时长、互动节点列表（可跳转到答题等互动环节）
+ (void)getStudentReplayInfoWithRoomID:(int64_t)roomID
                               success:(void (^)(ILILGetStudentReplayInfoResp *resp))success
                               failure:(void (^)(NSError *error))failure;

@end

NS_ASSUME_NONNULL_END
